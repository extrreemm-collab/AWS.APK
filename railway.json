{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/ams_project/backend/Dockerfile",
    "watchPatterns": [
      "/ams_project/backend/**"
    ]
  },
  "deploy": {
    "startCommand": "sh -c 'python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080}'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
